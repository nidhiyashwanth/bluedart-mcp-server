{
  "name": "bluedart-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server for the BlueDart (DHL eCommerce India) shipping API. Exposes waybill, pickup, transit-time, tracking and master-download tools to MCP clients (Claude Desktop, ChatGPT, etc.).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bluedart-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "stdio": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bluedart",
    "dhl",
    "shipping",
    "logistics",
    "india",
    "waybill",
    "tracking"
  ],
  "author": "Nidhi Singh",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
