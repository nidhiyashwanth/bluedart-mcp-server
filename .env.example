# BlueDart APIGEE base URL
# Sandbox: https://apigateway-sandbox.bluedart.com/in/transportation
# Prod:    https://apigateway.bluedart.com/in/transportation
BLUEDART_BASE_URL=https://apigateway-sandbox.bluedart.com/in/transportation

# OAuth credentials issued by BlueDart APIGEE for your app
BLUEDART_CLIENT_ID=
BLUEDART_CLIENT_SECRET=

# Customer profile credentials embedded in every BlueDart payload
BLUEDART_LOGIN_ID=
BLUEDART_LICENSE_KEY=

# 'S' for sandbox, 'T' (or as documented) for production
BLUEDART_API_TYPE=S

# Optional: set to 'true' for verbose stderr logs
BLUEDART_DEBUG=false
